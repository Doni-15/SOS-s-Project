generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  CASHIER
}

enum AvailabilityStatus {
  AVAILABLE
  OUT_OF_STOCK
}

enum OrderStatus {
  SUBMITTED
  ACCEPTED
  PAID
  CANCELLED
  EXPIRED
}

enum PaymentMethod {
  CASH
}

enum PrintStatus {
  GENERATED
  PRINTED
  FAILED
}

enum PrintAttemptStatus {
  SUCCESS
  FAILED
}

enum BackupType {
  MANUAL
  SCHEDULED
}

enum BackupStatus {
  STARTED
  SUCCESS
  FAILED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String?   @map("full_name") @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  role         UserRole
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions             UserSession[]
  acceptedOrders       Order[]
  transactions         Transaction[]
  receiptPrintAttempts ReceiptPrintAttempt[]
  idempotencyKeys      IdempotencyKey[]
  auditLogs            AuditLog[]
  backupLogs           BackupLog[]
  orderStatusHistories OrderStatusHistory[]

  @@index([role, isActive])
  @@index([isActive])
  @@map("users")
}

model UserSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  ipAddress String?   @map("ip_address") @db.VarChar(100)
  userAgent String?   @map("user_agent") @db.Text
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("user_sessions")
}

model DiningTable {
  id          String   @id @default(uuid()) @db.Uuid
  tableNumber String   @unique @map("table_number") @db.VarChar(20)
  label       String?  @db.VarChar(100)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  qrTokens      QrToken[]
  orderSessions OrderSession[]
  orders        Order[]

  @@index([isActive])
  @@map("dining_tables")
}

model QrToken {
  id        String    @id @default(uuid()) @db.Uuid
  tableId   String    @map("table_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  isRevoked Boolean   @default(false) @map("is_revoked")
  expiresAt DateTime? @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  table         DiningTable    @relation(fields: [tableId], references: [id], onDelete: Restrict)
  orderSessions OrderSession[]

  @@index([tableId, isRevoked])
  @@index([expiresAt])
  @@map("qr_tokens")
}

model OrderSession {
  id               String    @id @default(uuid()) @db.Uuid
  tableId          String    @map("table_id") @db.Uuid
  qrTokenId        String?   @map("qr_token_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(100)
  userAgent        String?   @map("user_agent") @db.Text
  expiresAt        DateTime  @map("expires_at")
  usedAt           DateTime? @map("used_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  table   DiningTable @relation(fields: [tableId], references: [id], onDelete: Restrict)
  qrToken QrToken?    @relation(fields: [qrTokenId], references: [id], onDelete: SetNull)
  orders  Order[]

  @@index([tableId, expiresAt])
  @@index([qrTokenId])
  @@index([expiresAt])
  @@map("order_sessions")
}

model MenuCategory {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique @db.VarChar(50)
  description  String?  @db.Text
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  menuItems MenuItem[]

  @@index([isActive, displayOrder])
  @@map("menu_categories")
}

model MenuItem {
  id                 String             @id @default(uuid()) @db.Uuid
  categoryId         String             @map("category_id") @db.Uuid
  name               String             @db.VarChar(100)
  description        String?            @db.Text
  price              Decimal            @db.Decimal(12, 2)
  imageUrl           String?            @map("image_url") @db.Text
  availabilityStatus AvailabilityStatus @default(AVAILABLE) @map("availability_status")
  isActive           Boolean            @default(true) @map("is_active")
  displayOrder       Int                @default(0) @map("display_order")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@index([categoryId, availabilityStatus, isActive])
  @@index([name])
  @@index([isActive, displayOrder])
  @@map("menu_items")
}

model Order {
  id               String      @id @default(uuid()) @db.Uuid
  orderNumber      String      @unique @map("order_number") @db.VarChar(50)
  tableId          String      @map("table_id") @db.Uuid
  orderSessionId   String?     @map("order_session_id") @db.Uuid
  acceptedByUserId String?     @map("accepted_by_user_id") @db.Uuid
  status           OrderStatus @default(SUBMITTED)
  totalAmount      Decimal     @map("total_amount") @db.Decimal(12, 2)
  customerNote     String?     @map("customer_note") @db.Text
  version          Int         @default(1)
  createdAt        DateTime    @default(now()) @map("created_at")
  submittedAt      DateTime    @default(now()) @map("submitted_at")
  acceptedAt       DateTime?   @map("accepted_at")
  cancelledAt      DateTime?   @map("cancelled_at")
  expiredAt        DateTime?   @map("expired_at")
  paidAt           DateTime?   @map("paid_at")

  table           DiningTable          @relation(fields: [tableId], references: [id], onDelete: Restrict)
  orderSession    OrderSession?        @relation(fields: [orderSessionId], references: [id], onDelete: SetNull)
  acceptedBy      User?                @relation(fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  transaction     Transaction?
  idempotencyKeys IdempotencyKey[]
  statusHistories OrderStatusHistory[]

  @@index([status, createdAt])
  @@index([tableId, status])
  @@index([orderSessionId])
  @@index([acceptedByUserId])
  @@map("orders")
}

model OrderItem {
  id                   String   @id @default(uuid()) @db.Uuid
  orderId              String   @map("order_id") @db.Uuid
  menuItemId           String   @map("menu_item_id") @db.Uuid
  itemNameSnapshot     String   @map("item_name_snapshot") @db.VarChar(100)
  categoryNameSnapshot String?  @map("category_name_snapshot") @db.VarChar(50)
  unitPriceSnapshot    Decimal  @map("unit_price_snapshot") @db.Decimal(12, 2)
  quantity             Int
  subtotal             Decimal  @db.Decimal(12, 2)
  note                 String?  @db.Text
  createdAt            DateTime @default(now()) @map("created_at")

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model OrderStatusHistory {
  id              String       @id @default(uuid()) @db.Uuid
  orderId         String       @map("order_id") @db.Uuid
  changedByUserId String?      @map("changed_by_user_id") @db.Uuid
  fromStatus      OrderStatus? @map("from_status")
  toStatus        OrderStatus  @map("to_status")
  note            String?      @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")

  order         Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser User? @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([changedByUserId])
  @@index([toStatus, createdAt])
  @@map("order_status_histories")
}

model Transaction {
  id                String        @id @default(uuid()) @db.Uuid
  transactionNumber String        @unique @map("transaction_number") @db.VarChar(50)
  orderId           String        @unique @map("order_id") @db.Uuid
  cashierUserId     String        @map("cashier_user_id") @db.Uuid
  paymentMethod     PaymentMethod @default(CASH) @map("payment_method")
  totalAmount       Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount        Decimal       @map("paid_amount") @db.Decimal(12, 2)
  changeAmount      Decimal       @map("change_amount") @db.Decimal(12, 2)
  transactionTime   DateTime      @default(now()) @map("transaction_time")
  createdAt         DateTime      @default(now()) @map("created_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  cashier User     @relation(fields: [cashierUserId], references: [id], onDelete: Restrict)
  receipt Receipt?

  @@index([transactionTime])
  @@index([cashierUserId, transactionTime])
  @@map("transactions")
}

model Receipt {
  id             String      @id @default(uuid()) @db.Uuid
  receiptNumber  String      @unique @map("receipt_number") @db.VarChar(50)
  transactionId  String      @unique @map("transaction_id") @db.Uuid
  printStatus    PrintStatus @default(GENERATED) @map("print_status")
  receiptPayload Json?       @map("receipt_payload")
  printedAt      DateTime?   @map("printed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  transaction   Transaction           @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  printAttempts ReceiptPrintAttempt[]

  @@index([transactionId])
  @@index([printStatus])
  @@map("receipts")
}

model ReceiptPrintAttempt {
  id            String             @id @default(uuid()) @db.Uuid
  receiptId     String             @map("receipt_id") @db.Uuid
  cashierUserId String?            @map("cashier_user_id") @db.Uuid
  status        PrintAttemptStatus
  errorMessage  String?            @map("error_message") @db.Text
  attemptedAt   DateTime           @default(now()) @map("attempted_at")

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  cashier User?   @relation(fields: [cashierUserId], references: [id], onDelete: SetNull)

  @@index([receiptId, attemptedAt])
  @@index([cashierUserId])
  @@index([status])
  @@map("receipt_print_attempts")
}

model IdempotencyKey {
  id              String   @id @default(uuid()) @db.Uuid
  key             String   @unique @db.VarChar(255)
  endpoint        String   @db.VarChar(255)
  requestHash     String   @map("request_hash") @db.VarChar(255)
  responsePayload Json?    @map("response_payload")
  userId          String?  @map("user_id") @db.Uuid
  orderId         String?  @map("order_id") @db.Uuid
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, endpoint])
  @@index([orderId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(100)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model BackupLog {
  id                String       @id @default(uuid()) @db.Uuid
  backupType        BackupType   @map("backup_type")
  status            BackupStatus
  filePath          String?      @map("file_path") @db.Text
  errorMessage      String?      @map("error_message") @db.Text
  triggeredByUserId String?      @map("triggered_by_user_id") @db.Uuid
  startedAt         DateTime     @default(now()) @map("started_at")
  completedAt       DateTime?    @map("completed_at")

  triggeredBy User? @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([status, startedAt])
  @@index([backupType, startedAt])
  @@index([triggeredByUserId])
  @@map("backup_logs")
}
